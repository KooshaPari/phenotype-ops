# phenotype-review-surface Environment Variables
# Copy to .env and fill in secrets

# GitHub (required)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-webhook-secret-from-github-settings

# Backend API Keys (optional, one per backend)
CODERABBIT_TOKEN=coderabbit_xxxxxxxxxxxxxxxxxxxxxxxx
CURSOR_WEBHOOK_URL=http://cursor-server:3000/api/review

# Redis (for production state persistence)
REDIS_URL=redis://localhost:6379/0

# Review Configuration
REVIEW_TOOL_BACKENDS=forge,coderabbit,copilot,cursor
REVIEW_DEFAULT_BACKEND=forge
REVIEW_RATE_LIMIT_PER_HOUR=30

# Server
REVIEW_PORT=8080
REVIEW_LOG_LEVEL=info