{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/policy-resolution.schema.json",
  "title": "PolicyResolutionPayload",
  "type": "object",
  "required": ["resolver_version", "scope", "policy", "applied_layers", "audit"],
  "properties": {
    "resolver_version": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["system", "user", "harness", "repo", "task_domain", "extensions"],
      "properties": {
        "system": { "type": "string" },
        "user": { "type": "string" },
        "harness": { "type": "string" },
        "repo": { "type": "string" },
        "task_domain": { "type": "string" },
        "extensions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "policy": { "type": "object" },
    "applied_layers": {
      "type": "array",
      "items": { "type": "object" }
    },
    "audit": {
      "type": "object",
      "properties": {
        "generated_at": { "type": "string" },
        "policy_digest": { "type": "string" },
        "policy_signature": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["generated_at", "policy_digest", "files"]
    }
  }
}
