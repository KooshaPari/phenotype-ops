{
  "name": "codex-gate",
  "version": "1.0.0",
  "kind": "policy-gate",
  "scope": "global",
  "targets": ["codex", "factory-droid"],
  "fragment": {
    "agent_governance": {
      "command_policy": {
        "require_closure_check": true,
        "required_readme_updates": true
      },
      "handoff": {
        "auto_summary": true
      }
    },
    "telemetry": {
      "track_pipeline": true
    }
  },
  "hooks": [
    {
      "name": "post-task-audit",
      "when": "post_task",
      "command": "python tools/federate_policy.py --repo {repo} --harness {harness} --user {user} --task-domain {task_domain} --extensions codex-gate --out {out}"
    }
  ],
  "integrations": ["codex", "cli-federation"],
  "enabled_by_default": true
}
