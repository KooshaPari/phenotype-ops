# agent-devops-setups - DevOps configuration
# Native task runner (just)

# Default recipe
default: help

# Help
help:
  @echo "agent-devops-setups - DevOps configuration"
  @echo ""
  @just --list

# Install dependencies
install:
  uv sync

# Quality checks
check: lint test
  @echo "All checks passed!"

# Lint
lint:
  uv run ruff check .

# Format
fmt:
  uv run ruff format .

# Run tests
test:
  uv run pytest tests/ -v

# Validate configurations
validate:
  uv run python scripts/validate.py

# Clean
clean:
  rm -rf .pytest_cache dist *.egg-info
