# agent-devops-setups - DevOps configuration management
# Required environment variables

# Configuration
DEVOPS_CONFIG_DIR=~/.config/agent-devops
DEVOPS_DATA_DIR=~/.local/share/agent-devops

# Logging
DEVOPS_LOG_LEVEL=DEBUG
DEVOPS_LOG_FORMAT=json

# Validation
DEVOPS_VALIDATE_ON_START=true
DEVOPS_STRICT_MODE=false

# CI/CD Providers (optional)
DEVOPS_GITHUB_TOKEN=your-github-token-here
DEVOPS_GITLAB_TOKEN=your-gitlab-token-here
