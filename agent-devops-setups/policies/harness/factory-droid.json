{
  "policy": {
    "harness": {
      "name": "Factory-Droid",
      "capabilities": {
        "parallel_agents": "high",
        "executor": "task"
      },
      "tool_contracts": {
        "shell": {
          "requires_signed_artifact": true,
          "forbidden_default": ["git commit --amend", "git push --force"]
        }
      },
      "routing": {
        "escalation_to": "human",
        "escalation_on": ["token_budget", "policy_violation"]
      }
    }
  }
}
