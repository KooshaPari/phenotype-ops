{
  "policy": {
    "harness": {
      "name": "Codex",
      "command_prefixes": [],
      "tool_contracts": {
        "shell": {
          "sandbox_mode": "workspace-write",
          "require_approval_for_unknown": true
        }
      },
      "tooling": {
        "prefer": ["shell_command", "apply_patch"],
        "avoid": ["git reset --hard", "python direct edits for simple tasks"]
      },
      "child_agents": {
        "max_parallel": 2,
        "default_profile": "research+implement"
      }
    }
  }
}
