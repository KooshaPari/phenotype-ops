{
  "policy": {
    "harness": {
      "name": "Claude",
      "command_prefixes": ["/bin/zsh", "git"],
      "tool_contracts": {
        "shell": {
          "require_ask_for_escalated_permissions": true,
          "forbidden_default": ["rm -rf .git", "git rebase --onto --hard"]
        }
      },
      "documentation_contract": {
        "respect_session_docs": true
      }
    }
  }
}
