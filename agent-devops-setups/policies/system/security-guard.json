{
  "policy": {
    "security": {
      "secret_scan": true,
      "allow_destructive_commands": false,
      "allow_branch_force_push": false,
      "allow_root_writes": false
    },
    "compliance": {
      "sensitive_file_guard": [
        "secrets.yml",
        "config/secrets.json",
        ".env"
      ]
    }
  }
}
