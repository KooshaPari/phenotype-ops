{
  "policy": {
    "agent_governance": {
      "required_mode": "production_ready",
      "consent_rules": {
        "destructive_actions": "ask",
        "network_access": "ask_on_unknown_hosts"
      },
      "policy_files": {
        "must_read": ["AGENTS.md", "CLAUDE.md"],
        "required_sections": [
          "security",
          "testing",
          "deployment",
          "handoff"
        ]
      },
      "ci": {
        "require_gates": true,
        "dry_run_first": true
      }
    },
    "telemetry": {
      "capture": true,
      "retention_days": 90
    }
  }
}
